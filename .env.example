# PLANTILLA DE VARIABLES DE ENTORNO
# Instrucciones para el administrador del servidor: 
# 1. Copie este archivo y renómbrelo a ".env"
# 2. Reemplace los valores de ejemplo por los valores reales de producción.

# Entorno de ejecución de la aplicación
FLASK_ENV=production
FLASK_APP=aquaraster.py

# Clave secreta para las sesiones de usuario y seguridad de Flask
# IMPORTANTE: Reemplazar por una cadena de texto larga y aleatoria
SECRET_KEY=escriba_su_clave_secreta_aqui_12345