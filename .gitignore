# Entorno virtual de Python
venv/
.venv/
env/
 
# Caché de Python
__pycache__/
*.py[cod]
 
# Base de datos (contiene usuarios reales, no va a Git)
instance/db.sqlite3
 
# Archivos subidos por usuarios (imágenes satelitales, pueden ser muy pesadas)
uploads/*
# Archivos de ejemplo
examples/*
# Marcador para que Git cree la carpeta vacía
!uploads/.gitkeep
 
# Variables de entorno (nunca subir claves reales)
.env
 
# Resultados y archivos temporales de sesión
*.json
*.csv
 
# Archivos de sistema
.DS_Store
Thumbs.db
 
# IDEs
.vscode/
.idea/
 